#!/bin/sh
# Validate conventional commit format: type(scope): description
# Allows: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
# Scope is optional. Description must be lowercase and ≤72 chars.

commit_msg=$(cat "$1")

# Skip merge commits
if echo "$commit_msg" | head -1 | grep -qE "^Merge "; then
  exit 0
fi

# Skip amend/fixup
if echo "$commit_msg" | head -1 | grep -qE "^(amend|fixup|squash)!"; then
  exit 0
fi

# Validate format
if ! echo "$commit_msg" | head -1 | grep -qE "^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_/-]+\))?!?: .{1,72}"; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "Expected: type(scope): description"
  echo "Types: feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert"
  echo "Scope: optional, lowercase (e.g. api, ui, db)"
  echo "Description: lowercase, max 72 chars, no period"
  echo ""
  echo "Examples:"
  echo "  feat(auth): add Pi wallet connection"
  echo "  fix(marketplace): resolve payment bypass vulnerability"
  echo "  docs: update security audit"
  echo ""
  echo "Your message: $(head -1 "$1")"
  exit 1
fi

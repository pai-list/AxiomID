#!/usr/bin/env sh
# ───────────────────────────────────────────────────────────────────
# AxiomID pre-commit hook — SOUL-aligned validation
# Combines greptile/check-pr + cli-review + greploop into one flow
# ───────────────────────────────────────────────────────────────────

# 1. Lint staged files (ESLint)
echo "🔍 Running lint-staged..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ lint-staged failed. Fix errors before committing."
  exit 1
fi

# 2. SOUL pre-commit validation (lint, typecheck, test, review, commit msg)
echo ""
echo "۞ Running SOUL pre-commit validation..."
node scripts/pre-commit-validate.mjs
if [ $? -ne 0 ]; then
  echo "❌ SOUL validation failed. Fix issues before committing."
  exit 1
fi

# 3. CodeRabbit local review (optional)
if command -v coderabbit &> /dev/null; then
  echo "🐇 Running CodeRabbit local review..."
  coderabbit review --type uncommitted --config .coderabbit.yaml 2>/dev/null || echo "⚠️  CodeRabbit review skipped"
fi

echo ""
echo "✅ Pre-commit checks passed! بسم الله الرحمن الرحيم"

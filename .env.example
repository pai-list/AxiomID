# ──────────────────────────────────────────────────────────────
# AxiomID — Environment Variables
#
# Copy to .env.local for local dev.
# Production values are set in the Vercel dashboard.
# ──────────────────────────────────────────────────────────────

# ── Database (Neon / Vercel Postgres) ─────────────────────────
# Get from: https://vercel.com/marketplace/neon
DATABASE_URL="postgresql://..."

# ── Pi Network SDK ───────────────────────────────────────────
# Sandbox mode: true for dev, false/absent for production
NEXT_PUBLIC_PI_SANDBOX=true
# Sandbox dev token for local development. The bypass is disabled entirely in
# production (NODE_ENV=production), so any value set here is ignored there.
# Server-only override (preferred for shared/CI dev environments):
# SANDBOX_DEV_TOKEN="your-uuid-here"
# Public override — must match on client and server for the dev login flow.
# Defaults to "sandbox-dev-token-abc-123" when unset.
# NEXT_PUBLIC_SANDBOX_DEV_TOKEN="sandbox-dev-token-abc-123"
# Server-side API key from https://developer.minepi.com
# Required for payment approve/complete, KYC verify, and ad verification.
# Set in Vercel Production env; also set in Development for local testing.
# Generate: Pi Developer Portal → Your App → API Keys
PI_API_KEY=
# Pi Sign-in OAuth Client ID (public, used in redirect URL)
# From: https://developer.minepi.com → App → OAuth Client ID
NEXT_PUBLIC_PI_OAUTH_CLIENT_ID=

# ── Auth & Security ──────────────────────────────────────────
# Key for encrypting Pi access tokens at rest (32-byte hex)
# Generate with: openssl rand -hex 32
PI_TOKEN_ENCRYPTION_KEY=
# Key for signing OAuth state tokens (CSRF protection)
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=
# Auth token secret (server-side JWT signing)
# Generate with: openssl rand -hex 32
AUTH_TOKEN_SECRET=
# Ed25519 private key for signing Verifiable Credentials (PEM format)
ISSUER_PRIVATE_KEY=
# Ed25519 public key for VC verification (PEM format)
ISSUER_PUBLIC_KEY=

# ── Client-Side (NEXT_PUBLIC) ────────────────────────────────
# Network label displayed in status page
NEXT_PUBLIC_NETWORK=Pi Testnet
# Site URL for Pi sandbox communication
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Dev URL for Pi sandbox fallback
NEXT_PUBLIC_DEV_URL=http://localhost:3000
# App URL override
# NEXT_PUBLIC_APP_URL=
# App version displayed in UI
# NEXT_PUBLIC_APP_VERSION=1.0.0
# Enable GitHub emulation in dev
# NEXT_PUBLIC_EMULATE_GITHUB=true
# Sandbox override flag
# NEXT_PUBLIC_SANDBOX_OVERRIDE=

# ── Vercel Cron ──────────────────────────────────────────────
# Bearer token for cron-triggered sync endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Telegram Bot ────────────────────────────────────────────
# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# ── Stellar ──────────────────────────────────────────────────
# Stellar network passphrase (e.g. "Pi Testnet" or "Public Global Stellar Network ; September 2015")
STELLAR_NETWORK=
# Stellar secret key for anchoring operations
STELLAR_SECRET_KEY=

# ── IPFS / Pinata ───────────────────────────────────────────
# Pinata JWT for IPFS uploads
PINATA_JWT=

# ── Admin ───────────────────────────────────────────────────
# Comma-separated wallet addresses with admin privileges
ADMIN_WALLETS=

# ── Optional ─────────────────────────────────────────────────
# GROQ_API_KEY=
# PERPLEXITY_API_KEY=
# Google Search Console verification code (meta tag)
# GOOGLE_SITE_VERIFICATION=
# Emulate service (local dev only)
# EMULATE_ENABLED=true
# Generic secret fallback
# SECRET=

# ── Cloudflare Backend ───────────────────────────────────────
# Cloudflare Worker URL (e.g. https://axiomid-backend.<your-subdomain>.workers.dev)
CLOUDFLARE_BACKEND_URL=
# Shared secret for Vercel ↔ Cloudflare auth (generate with: openssl rand -hex 32)
SHARED_SECRET_TOKEN_VERCEL_CF=

# ── Cloudflare R2 (Image Storage) ────────────────────────────
# Get from: https://dash.cloudflare.com → R2 → Overview
CLOUDFLARE_ACCOUNT_ID=
# R2 bucket name (create in Cloudflare Dashboard)
R2_BUCKET_NAME=axomid-images
# R2 public domain (enable public access in bucket settings)
R2_PUBLIC_DOMAIN=
# R2 S3-compatible access key (for presigned URL generation)
CLOUDFLARE_R2_ACCESS_KEY_ID=
# R2 S3-compatible secret key (for presigned URL generation)
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# ── Upstash Redis (Rate Limiting in Production) ──────────────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Vercel Speed Insights ────────────────────────────────────
# No env var needed — just install @vercel/speed-insights

# ── Here.now (Passport Publishing) ──────────────────────────
# Get from: https://here.now → Settings → API Tokens
HERENOW_TOKEN=
HERENOW_API_URL=https://api.here.now/v1

# ── npm Publishing ───────────────────────────────────────────
# Automation token from npmjs.com → Access Tokens → Generate
# Used by .github/workflows/npm-publish.yml (GitHub secret NPM_TOKEN)
NPM_TOKEN=

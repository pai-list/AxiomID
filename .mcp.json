{
  "mcpServers": {
    "autonoma": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://api.autonoma.app/v1/mcp/onboarding"],
      "env": {
        "AUTONOMA_CLIENT_ID": "YOUR_AUTONOMA_CLIENT_ID",
        "AUTONOMA_SECRET_ID": "YOUR_AUTONOMA_SECRET_ID"
      }
    },
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": true,
      "oauth": {}
    },
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "enabled": true
    },
    "cloudflare-bindings": {
      "type": "remote",
      "url": "https://bindings.mcp.cloudflare.com/mcp",
      "enabled": true,
      "oauth": {}
    },
    "cloudflare-builds": {
      "type": "remote",
      "url": "https://builds.mcp.cloudflare.com/mcp",
      "enabled": true,
      "oauth": {}
    },
    "cloudflare-observability": {
      "type": "remote",
      "url": "https://observability.mcp.cloudflare.com/mcp",
      "enabled": true,
      "oauth": {}
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {}
    },
    "resend": {
      "command": "npx",
      "args": ["-y", "resend-mcp"],
      "env": {
        "RESEND_API_KEY": "re_123456789_placeholder"
      }
    }
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// IDENTITY & KYC
// ─────────────────────────────────────────────

model User {
  id             String  @id @default(uuid())
  walletAddress  String  @unique @db.VarChar(120)
  stellarAddress String? @db.VarChar(56)
  piUid          String? @unique @db.VarChar(100)
  piUsername     String? @db.VarChar(100)
  piAccessToken  String? // encrypted at rest (AES-256-GCM)

  // XP & Tier (denormalized from XpLedger for fast reads)
  xp   Int    @default(0)
  tier String @default("Visitor") @db.VarChar(50)

  // Sovereign DID
  did       String? @unique @db.VarChar(255)
  didMethod String? @default("did:axiom") @db.VarChar(50)

  // KYC
  kycStatus     KYCStatus @default(NONE)
  kycProvider   String? // "pi_network" | "world_id" | "gitcoin"
  kycAssurance  String? // "low" | "substantial" | "high"
  kycUidHash    String? // privacy-preserving hash
  kycVerifiedAt DateTime?

  // Passport Publishing
  passportUrl String? @db.VarChar(500) // published passport URL (here.now)

  // Subdomain
  subdomain String? @unique @db.VarChar(50) // user.axiomid.app

  // Agent
  agent UserAgent?

  // Actions
  actions  Action[]
  stamps   Stamp[]
  xpLedger XpLedger[]

  // Payments
  payments PiPayment[]

  // Agent Logs
  agentLogs AgentLog[]

  // Skills (authored)
  authoredSkills Skill[]

  // Skill Reviews
  skillReviews SkillReview[]

  // Skill Versions (authored)
  skillVersions SkillVersion[]

  // Skill Moderation (reviewed)
  moderatedSkills SkillModeration[]

  // Delegated Trust
  delegatedTrustFrom DelegatedTrust[] @relation("DelegatedTrustFrom")
  delegatedTrustTo   DelegatedTrust[] @relation("DelegatedTrustTo")

  // Ephemeral DIDs
  ephemeralDids EphemeralDid[]

  // Staking & Slashing
  stakes         Stake[]
  slashingEvents SlashingEvent[]

  // Metadata
  metadata   String?   @db.Text // JSON: arbitrary user metadata (max ~10KB)
  lastActive DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum KYCStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

// ─────────────────────────────────────────────
// AGENT SYSTEM
// ─────────────────────────────────────────────

model UserAgent {
  id       String @id @default(uuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicId String @unique @default(cuid()) // ag_xxx

  // Identity
  name        String  @default("My Agent") @db.VarChar(100)
  description String? @db.VarChar(500)
  avatarUrl   String? @db.VarChar(500)
  did         String? @db.VarChar(255)
  subdomain   String? @unique @db.VarChar(50) // agent.axiomid.app

  // State
  status AgentStatus @default(INACTIVE) // inactive | active | paused | sleeping
  mode   AgentMode   @default(AUTONOMOUS) // autonomous | supervised | manual

  // Runtime
  lastActive    DateTime?
  lastHeartbeat DateTime?
  activeUntil   DateTime?
  memoryLimit   Int       @default(500) // max memory entries

  // Logs
  agentLogs AgentLog[]

  // Skills (installed)
  installedSkills SkillInstallation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AgentStatus {
  INACTIVE
  ACTIVE
  PAUSED
  SLEEPING
}

enum AgentMode {
  AUTONOMOUS
  SUPERVISED
  MANUAL
}

enum PaymentStatus {
  PENDING
  ESCROWED
  RELEASED
  REFUNDED
}

// ─────────────────────────────────────────────
// PI BLOCKCHAIN PAYMENTS
// ─────────────────────────────────────────────

model PiPayment {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId   String        @unique // Pi Network payment ID
  txid        String? // blockchain transaction hash
  amount      Float
  memo        String?       @db.VarChar(500)
  metadata    String?       @db.Text // JSON: { skillId, agentId, purpose }
  status      PaymentStatus @default(PENDING)
  fromAddress String?
  toAddress   String?
  network     String        @default("pi")

  // Set when this payment has been redeemed for a skill install, so a single
  // RELEASED payment cannot be reused to reinstall a skill for free after an
  // uninstall. References SkillInstallation.id (no FK: installations may be
  // deleted on uninstall while the consumption record is retained).
  consumedByInstallationId String? @db.VarChar(36)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status, consumedByInstallationId])
}

// ─────────────────────────────────────────────
// ACTIONS & XP LEDGER
// ─────────────────────────────────────────────

model Action {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(50) // "connect_twitter" | "daily_pow" | etc
  xp         Int
  metadata   String?  @db.Text // JSON: extra context
  timestamp  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash       String?  @unique @db.VarChar(64)
  parentHash String?  @db.VarChar(64)

  @@unique([userId, type], name: "user_action_unique")
  @@index([userId])
  @@index([type])
}

model XpLedger {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int // positive = earned, negative = spent
  reason    String   @db.VarChar(50) // "action_claim" | "agent_create" | "admin_adjust"
  reference String?  @db.Text // JSON: { actionId, agentId }
  balance   Int // running balance after this entry
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// AGENT LOGS
// ─────────────────────────────────────────────

model AgentLog {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String?
  agent     UserAgent? @relation(fields: [agentId], references: [id])
  level     String     @default("info") @db.VarChar(20) // "debug" | "info" | "warn" | "error" | "critical"
  source    String     @db.VarChar(50) // "system" | "agent" | "skill" | "tool" | "user" | "payment"
  message   String     @db.VarChar(2000)
  metadata  String?    @db.Text // JSON
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([agentId])
  @@index([level])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// CRYPTOGRAPHIC STAMPS
// ─────────────────────────────────────────────

model Stamp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(50) // "connect_twitter" | "connect_discord" | "connect_google" | "daily_pow" | "wallet_age" | "verify_identity"
  provider  String   @db.VarChar(50) // "twitter" | "discord" | "google" | "pi" | "system"
  xpAwarded Int      @default(0)
  metadata  String?  @db.Text // Stores the stringified W3C VC
  createdAt DateTime @default(now())

  @@unique([userId, type], name: "user_stamp_unique")
  @@index([userId])
}

// ─────────────────────────────────────────────
// AGENTIC MARKETPLACE — GENOMIC REPOSITORY
// ─────────────────────────────────────────────

enum SkillTier {
  BASIC_TOOL
  ADVANCED_TOOL
  ADVANCED_INFRASTRUCTURE
  PRO
  SOVEREIGN
}

enum SkillStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

model Skill {
  id          String  @id @default(uuid())
  slug        String  @unique @db.VarChar(100) // "agent-memory"
  name        String  @db.VarChar(200) // "Agent Memory"
  description String? @db.VarChar(1000)

  // ── The Genomic Payload ──
  manifestMd  String  @db.Text // Full SKILL.md content with XML tags
  agentScript String? @db.Text // Specialist agent TypeScript code
  testSuite   String? @db.Text // Test suite to verify skill integrity

  // ── Marketplace Metadata ──
  tier        SkillTier   @default(BASIC_TOOL)
  pricePi     Float       @default(0) // Price in Pi tokens (0 = free)
  version     String      @default("1.0.0") @db.VarChar(20) // Semantic version
  authorId    String?
  author      User?       @relation(fields: [authorId], references: [id])
  status      SkillStatus @default(DRAFT)
  isPublished Boolean     @default(false)

  // ── Analytics ──
  installCount Int   @default(0)
  avgRating    Float @default(0) // 0-5 scale
  ratingCount  Int   @default(0)

  // ── Relations ──
  installations SkillInstallation[]
  reviews       SkillReview[]
  tags          SkillTagRelation[]
  versions      SkillVersion[]
  moderation    SkillModeration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tier])
  @@index([status])
  @@index([isPublished])
  @@index([slug])
}

model SkillInstallation {
  id          String    @id @default(uuid())
  skillId     String
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  agentId     String
  agent       UserAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  installedAt DateTime  @default(now())
  status      String    @default("active") @db.VarChar(20) // "active" | "disabled" | "pending"

  @@unique([skillId, agentId], name: "skill_agent_unique")
  @@index([skillId])
  @@index([agentId])
}

model SkillReview {
  id        String   @id @default(uuid())
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1-5 stars
  review    String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([skillId, userId], name: "skill_user_review_unique")
  @@index([skillId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// MARKETPLACE — TAGS, VERSIONS, MODERATION
// ─────────────────────────────────────────────

model SkillTag {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(500)
  color       String?  @db.VarChar(7) // hex color e.g. "#3b82f6"
  createdAt   DateTime @default(now())

  skills SkillTagRelation[]
}

model SkillTagRelation {
  id        String   @id @default(uuid())
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tagId     String
  tag       SkillTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([skillId, tagId], name: "skill_tag_unique")
  @@index([skillId])
  @@index([tagId])
}

model SkillVersion {
  id          String      @id @default(uuid())
  skillId     String
  skill       Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  version     String      @db.VarChar(20) // semver "1.2.3"
  manifestMd  String      @db.Text
  agentScript String?     @db.Text
  testSuite   String?     @db.Text
  changelog   String?     @db.Text
  authorId    String?
  author      User?       @relation(fields: [authorId], references: [id])
  status      SkillStatus @default(DRAFT)
  createdAt   DateTime    @default(now())

  @@unique([skillId, version], name: "skill_version_unique")
  @@index([skillId])
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model SkillModeration {
  id         String           @id @default(uuid())
  skillId    String
  skill      Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)
  status     ModerationStatus @default(PENDING)
  reviewerId String?
  reviewer   User?            @relation(fields: [reviewerId], references: [id])
  reason     String?          @db.VarChar(1000)
  notes      String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([skillId])
  @@index([status])
  @@index([reviewerId])
}

// ─────────────────────────────────────────────
// TRUST DELEGATION
// ─────────────────────────────────────────────

model DelegatedTrust {
  id        String   @id @default(uuid())
  fromDid   String   @db.VarChar(255) // The delegating DID
  fromUser  User     @relation("DelegatedTrustFrom", fields: [fromDid], references: [did], onDelete: Cascade)
  toDid     String   @db.VarChar(255) // The trusted DID
  toUser    User     @relation("DelegatedTrustTo", fields: [toDid], references: [did], onDelete: Cascade)
  weight    Float    @default(1.0) // Trust weight (0.0 - 1.0)
  createdAt DateTime @default(now())

  @@unique([fromDid, toDid], name: "delegation_unique")
}

model EphemeralDid {
  id        String             @id @default(uuid())
  did       String             @unique @db.VarChar(255)
  parentDid String?            @db.VarChar(255)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  status    EphemeralDidStatus @default(ACTIVE)
  createdAt DateTime           @default(now())

  @@index([userId])
}

enum EphemeralDidStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// ─────────────────────────────────────────────
// AGENT SELF-REVIEW LOGS (META-LOOP)
// ─────────────────────────────────────────────

model SelfReviewLog {
  id         String   @id @default(uuid())
  actionName String   @db.VarChar(255)
  score      Float
  critique   String   @db.Text
  telemetry  String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([actionName])
}

// ─────────────────────────────────────────────
// HARVEST RESULTS (Perplexity → Cloudflare)
// ─────────────────────────────────────────────

model HarvestResult {
  id        String   @id @default(uuid())
  query     String   @db.Text
  result    String   @db.Text
  citations String?  @db.Text // JSON array of citation URLs
  userDid   String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  @@index([userDid])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// AGENT PRESENCE (Edge tracking)
// ─────────────────────────────────────────────

model AgentPresence {
  agentId       String   @id @default(uuid())
  status        String   @default("offline") @db.VarChar(20)
  lastHeartbeat BigInt?
  metadata      String?  @db.Text // JSON blob for agent-specific data
  updatedAt     DateTime @updatedAt
}

model Claim {
  id              String   @id @default(uuid())
  token           String   @unique @db.VarChar(255)
  userCode        String   @db.VarChar(50)
  verificationUri String   @db.VarChar(255)
  expiresAt       DateTime
  userId          String?  @db.VarChar(255)
  status          String   @default("pending") @db.VarChar(50) // "pending" | "confirmed" | "expired"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([token])
  @@index([userCode])
  @@index([status])
}

// ─────────────────────────────────────────────
// STAKING & SLASHING (Phase 3)
// ─────────────────────────────────────────────

model Stake {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(20, 8)
  status     String   @default("staked") // staked | unstaked
  createdAt  DateTime @default(now())

  @@index([userId])
}

model SlashingEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(20, 8)
  reason    String   @db.VarChar(500)
  createdAt DateTime @default(now())

  @@index([userId])
}


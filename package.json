{
  "name": "axiomid",
  "version": "0.2.0",
  "private": true,
  "description": "AxiomID - The Human Authorization Protocol. Decentralized identity verification for human-AI collaboration.",
  "aix": {
    "stackVersion": "0.369.0",
    "stackCodename": "Echo369",
    "spec": "AIX/1.0",
    "layer": "L0",
    "layerName": "root-authority",
    "authority": "axiomid.app"
  },
  "author": "Mohamed Abdelaziz <https://github.com/Moeabdelaziz007>",
  "homepage": "https://axiomid.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moeabdelaziz007/AxiomID.git"
  },
  "bugs": {
    "url": "https://github.com/Moeabdelaziz007/AxiomID/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "decentralized-identity",
    "human-verification",
    "ai-authorization",
    "blockchain",
    "sybil-resistance",
    "web3",
    "nextjs",
    "typescript",
    "framer-motion"
  ],
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "next build && next start",
    "analyze": "ANALYZE=true next build",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "test": "NODE_OPTIONS='--no-deprecation' jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "memory:build": "ts-node --compiler-options '{\\\"module\\\":\\\"commonjs\\\"}' scripts/build-memory.ts",
    "dead-code": "knip",
    "a11y": "npx pa11y-ci --config .pa11yci.json",
    "prisma:seed-tags": "npx tsx prisma/seed-tags.ts",
    "pre-commit": "node scripts/pre-commit-validate.mjs",
    "build": "prisma generate && next build"
  },
  "dependencies": {
    "@axiomid/crypto": "^0.1.0",
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "@nostics/unplugin": "^1.1.0",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "@types/d3": "^7.4.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "isomorphic-dompurify": "^2.26.0",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "d3": "^7.9.0",
    "framer-motion": "^12.42.2",
    "html2canvas": "^1.4.1",
    "jose": "^5.9.6",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "nostics": "^1.1.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "sonner": "^2.0.7",
    "stellar-sdk": "^13.3.0",
    "telegraf": "^4.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@emulators/adapter-next": "^0.9.0",
    "@emulators/github": "^0.9.0",
    "@playwright/test": "^1.61.1",
    "@sentry/nextjs": "^10.65.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-location-mock": "^4.0.1",
    "knip": "^6.26.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "undici": "^8.7.0"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "workspaces": [
    "packages/*"
